{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ElmaClient": {
    "BaseUrl": "https://elma.nass.usda.gov/",
    "FoUpdateRequestPath": "FO/FOUpdateRequest.aspx",
