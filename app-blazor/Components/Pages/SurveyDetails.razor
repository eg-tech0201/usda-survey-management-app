@page "/surveys/details"
@page "/surveys/details/{SurveyId:int?}"
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<h1>Survey Details</h1>

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-outline-primary"
       href="@BuildDetailExportUrl()">Export CSV</a>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class='nav-link @(ActiveTab == "Overview" ? "active" : "")' @onclick='@(() => SetTab("Overview"))'>Overview</button>
    </li>
    <li class="nav-item">
        <button class='nav-link @(ActiveTab == "Counts" ? "active" : "")' @onclick='@(() => SetTab("Counts"))'>Counts</button>
    </li>
    <li class="nav-item">
        <button class='nav-link @(ActiveTab == "FullRecord" ? "active" : "")' @onclick='@(() => SetTab("FullRecord"))'>Full Record</button>
    </li>
</ul>

@if (IsLoading)
{
    <div class="alert alert-info">Loading survey details...</div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-warning">@ErrorMessage</div>
}
else if (Detail is null)
{
    <div class="alert alert-warning">No survey detail found for the selected instance.</div>
}
else if (ActiveTab == "Overview")
{
    <div class="card mb-3">
        <div class="card-header">Survey Info</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4"><strong>Sample ID:</strong> @Detail.SampleId</div>
                <div class="col-md-8"><strong>Sample Name:</strong> @Detail.SampleName</div>
                <div class="col-md-4"><strong>Survey ID:</strong> @Detail.SurveyId</div>
                <div class="col-md-8"><strong>Title:</strong> @Detail.Title</div>
                <div class="col-md-8"><strong>Sub Title:</strong> @Detail.SubTitle</div>
                <div class="col-md-4"><strong>Survey Frequency:</strong> @Detail.SurveyFrequency</div>
                <div class="col-md-4"><strong>Version:</strong> @Detail.Version</div>
                <div class="col-md-4"><strong>Survey Date:</strong> @Detail.SurveyDate.ToString("yyyy-MM-dd")</div>
                <div class="col-md-4"><strong>Reference Date:</strong> @Detail.ReferenceDate.ToString("yyyy-MM-dd")</div>
                <div class="col-md-4"><strong>HQ Survey Admin:</strong> @Detail.HqSurveyAdmin</div>
                <div class="col-md-4"><strong>Project Code:</strong> @Detail.ProjectCode</div>
                <div class="col-md-4"><strong>Survey Start:</strong> @Detail.SurveyStartDate.ToString("yyyy-MM-dd")</div>
                <div class="col-md-4"><strong>Survey Stop:</strong> @Detail.SurveyStopDate.ToString("yyyy-MM-dd")</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Available Modes</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mode</th>
                            <th>Start Date</th>
                            <th>Stop Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mode in Detail.Modes)
                        {
                            <tr>
                                <td>@mode.Mode</td>
                                <td>@mode.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@mode.StopDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (ActiveTab == "FullRecord")
{
    <div class="card">
        <div class="card-header">Full Record</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Field</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var field in Detail.FullRecord)
                        {
                            <tr>
                                <td>@field.Field</td>
                                <td>@field.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-header">Survey Counts by OpDom Status</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Status</th>
                            <th>Definition</th>
                            <th>Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Detail.OpDomCounts)
                        {
                            <tr>
                                <td>@item.Code</td>
                                <td class="text-muted">@item.Definition</td>
                                <td>@item.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Survey Counts by DCMS Code</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th>
                            <th>Definition</th>
                            <th>Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Detail.DcmsCounts)
                        {
                            <tr>
                                <td>@item.Code</td>
                                <td class="text-muted">@item.Definition</td>
                                <td>@item.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Totals</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4"><strong>Total Received:</strong> @Detail.TotalReceived</div>
                <div class="col-md-4"><strong>Total Deleted:</strong> @Detail.TotalDeleted</div>
                <div class="col-md-4"><strong>Budget Allocation:</strong> @Detail.BudgetAllocation.ToString("C0")</div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? SurveyId { get; set; }
    [SupplyParameterFromQuery(Name = "surveyId")] public int? SurveyIdQuery { get; set; }
    [SupplyParameterFromQuery(Name = "sampleId")] public string? SampleId { get; set; }
    [SupplyParameterFromQuery(Name = "referenceDate")] public string? ReferenceDate { get; set; }

    private string ActiveTab { get; set; } = "Overview";
    private app_blazor.Services.SurveyInstanceDetailResponse? Detail { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;
        Detail = null;

        var surveyId = SurveyIdQuery ?? SurveyId;
        if (!surveyId.HasValue || string.IsNullOrWhiteSpace(SampleId) || string.IsNullOrWhiteSpace(ReferenceDate))
        {
            ErrorMessage = "Select Reference Date, Survey ID, and Sample ID on the Surveys page to view details.";
            return;
        }

        IsLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri(Navigation.BaseUri);

            var url =
                $"api/survey-instances/detail?referenceDate={Uri.EscapeDataString(ReferenceDate)}&surveyId={surveyId.Value}&sampleId={Uri.EscapeDataString(SampleId)}";
            Detail = await client.GetFromJsonAsync<app_blazor.Services.SurveyInstanceDetailResponse>(url);
        }
        catch
        {
            ErrorMessage = "Unable to load survey details. Please try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SetTab(string tab) => ActiveTab = tab;

    private string BuildDetailExportUrl()
    {
        var surveyId = SurveyIdQuery ?? SurveyId;
        if (!surveyId.HasValue || string.IsNullOrWhiteSpace(SampleId) || string.IsNullOrWhiteSpace(ReferenceDate))
            return "#";

        return $"/api/survey-instances/detail-export?referenceDate={Uri.EscapeDataString(ReferenceDate)}&surveyId={surveyId.Value}&sampleId={Uri.EscapeDataString(SampleId)}";
    }
}
