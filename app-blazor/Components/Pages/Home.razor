@page "/"
@using app_blazor.Components.Shared
@using static app_blazor.Components.Shared.TaskCalendar
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject IHttpClientFactory HttpClientFactory
@inject app_blazor.Services.SurveyInstanceService SurveyInstanceService

<h2 class="page-h2">Dashboard</h2>

<div class="dashboard-grid dashboard-two-col" @onclick="ClearSelection">
    <section class="panel calendar-panel dashboard-col-1 dashboard-row-1">
        <div class="calendar-panel-header">
            <a class="panel-title-link" href="/calendar">My Tasks</a>
            <div class="calendar-view-toggle">
                <button type="button" class="button-lite @(ShowTaskList ? "active" : "")" @onclick="() => ShowTaskList = true">List View</button>
                <button type="button" class="button-lite @(!ShowTaskList ? "active" : "")" @onclick="() => ShowTaskList = false">Calendar View</button>
            </div>
        </div>

        @if (ShowTaskList)
        {
            <div class="tasks-list">
                @if (Tasks.Count == 0)
                {
                    <div class="tasks-empty">No tasks yet.</div>
                }
                else
                {
                    <table class="table-lite">
                        <thead>
                            <tr>
                                <th style="width: 30%">Task</th>
                                <th style="width: 24%">Survey</th>
                                <th style="width: 30%">Due Date</th>
                                <th style="width: 16%">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Tasks)
                            {
                                <tr class="task-row @(SelectedEventId == t.Id ? "selected" : "")"
                                    @onclick="() => SelectTask(t)" @onclick:stopPropagation="true">
                                    <td>
                                        <a class="task-link" href="@GetSurveyLink(t.SurveyId)" @onclick:stopPropagation="true">
                                            @t.Task
                                        </a>
                                    </td>
                                    <td>
                                        <a class="task-link" href="@GetSurveyLink(t.SurveyId)" @onclick:stopPropagation="true">
                                            @t.SurveyId @t.SurveyTitle
                                        </a>
                                    </td>
                                    <td>@t.DueAt.ToString("MMM d, h:mm tt")</td>
                                    <td><span class="pill @GetPill(t.Status)">@t.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
        else
        {
            <TaskCalendar Events="CalendarEvents"
                          @bind-View="CalendarView"
                          @bind-SelectedEventId="SelectedEventId" />
        }
    </section>

    <div class="dashboard-stack dashboard-col-2 dashboard-row-1">
        <section class="panel stats-panel stats-panel-bubbles">
            <div class="stats-header">Survey Statistics</div>
            <div class="stats-grid stats-grid-bubbles">
                <div class="stat-tile">
                    <div class="stat-label">Number of survey instruments served to date:</div>
                    <div class="stat-value">0</div>
                </div>
                <div class="stat-tile">
                    <div class="stat-label">Number of respondents sampled to date:</div>
                    <div class="stat-value">3,562,523</div>
                </div>
                <div class="stat-tile">
                    <div class="stat-label">Number of responses to date:</div>
                    <div class="stat-value">1,097,260</div>
                </div>
                <div class="stat-tile">
                    <div class="stat-label">Response rate to date:</div>
                    <div class="stat-value">5.4417%</div>
                </div>
                <div class="stat-tile">
                    <div class="stat-label">Average customer experience:</div>
                    <div class="stat-value">Not available</div>
                </div>
            </div>
        </section>

        <section class="panel surveys-search-panel">
            <div class="panel-title-row">
                <a class="panel-title-link" href="/surveys">Survey Search</a>
            </div>
            <div class="selector-row">
                <div class="selector-field">
                    <label class="selector-label">Reference Date</label>
                    <InputDate class="select-lite"
                               @bind-Value="SelectedReferenceDate"
                               @bind-Value:after="OnReferenceDateChanged" />
                </div>
                <div class="selector-field">
                    <label class="selector-label">Survey ID</label>
                    <select class="select-lite"
                            value="@SelectedSurveyIdString"
                            @onchange="OnSurveyIdChanged">
                        <option value="">Select survey</option>
                        @foreach (var id in AvailableSurveyIds)
                        {
                            <option value="@id">@id</option>
                        }
                    </select>
                </div>
                <div class="selector-field">
                    <label class="selector-label">Sample ID</label>
                    <select class="select-lite"
                            value="@SelectedSampleId"
                            @onchange="OnSampleIdChanged">
                        <option value="">Select sample</option>
                        @foreach (var sample in AvailableSampleIds)
                        {
                            <option value="@sample">@sample</option>
                        }
                    </select>
                </div>
                <div class="selector-actions">
                    <button class="button-primary" type="button" @onclick="NavigateToSelectedDetails" disabled="@(!CanViewDetails)">
                        View Details
                    </button>
                </div>
            </div>
            <div class="search-input-row">
                <button class="search-icon-button" type="button" title="Search">
                    <span class="bi bi-search" aria-hidden="true"></span>
                </button>
                <input class="survey-search search-input"
                       placeholder="Search survey list (ID / title / OMB / sample)…"
                       @bind="SearchText"
                       @bind:event="oninput" />
                <button class="search-filter-button" type="button" title="Filters">
                    <span class="bi bi-sliders" aria-hidden="true"></span>
                    <span class="filter-label">Filters</span>
                </button>
            </div>
            @if (!string.IsNullOrWhiteSpace(OptionsMessage))
            {
                <div class="selector-message">@OptionsMessage</div>
            }
        </section>

        <section class="panel recent-surveys-panel">
            <div class="panel-title-row">
                <div class="panel-title">Recent Surveys</div>
                <a class="panel-title-link" href="/surveys/results">View all</a>
            </div>
            @if (RecentSurveyInstances.Count == 0)
            {
                <div class="empty-hint">No recent surveys available.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Survey ID</th>
                                <th>Title</th>
                                <th>Sample ID</th>
                                <th>Reference Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var survey in RecentSurveyInstances)
                            {
                                <tr>
                                    <td>
                                        <a class="table-link" href="@BuildDetailsHref(survey)">@survey.SurveyId</a>
                                    </td>
                                    <td>
                                        <a class="table-link" href="@BuildDetailsHref(survey)">@survey.Title</a>
                                    </td>
                                    <td>@survey.SampleId</td>
                                    <td>@survey.ReferenceDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>

@code {
    private TaskCalendar.CalendarViewMode CalendarView = TaskCalendar.CalendarViewMode.Month;
    private int? SelectedEventId { get; set; }
    private bool ShowTaskList { get; set; } = true;


    // DueAt includes the time
    private record TaskRow(int Id, string Task, int SurveyId, string SurveyTitle, DateTime DueAt, string Status);

    private List<TaskRow> Tasks = new()
    {
        new(1, "Finalize survey iteration dates", 1001, "Crop Yield Survey",
            new DateTime(2026, 1, 26, 17, 0, 0), 
            "In progress"), // 5:00PM
        new(2, "Validate status master (pre-publish)", 1002, "Ag Census Pilot",
            new DateTime(2026, 1, 18, 10, 0, 0), 
            "Blocked"), //10:00 AM
        new(3, "Review questionnaire link (instrument)", 1001, "Crop Yield Survey",
            new DateTime(2026, 1, 22, 14, 30, 0), 
            "Not started"), // 2:30 PM
        new(4, "Resolve schedule conflict (overlap)", 1004, "Dairy Inventory",
            new DateTime(2026, 1, 17, 9, 0, 0), 
            "Overdue"), //9:00 AM
        new(5, "Confirm CAWI mode dates", 1003, "Farm Labor Study",
            new DateTime(2026, 1, 11, 16, 0, 0), 
            "In progress"), // 4:00 PM
    };

    private List<TaskCalendar.CalendarEvent> CalendarEvents =>
    Tasks.Select(t => new TaskCalendar.CalendarEvent
    {
        Id = t.Id,
        Start = t.DueAt, // <-- IMPORTANT (CalendarEvent should have Start)
        Title = $"{t.SurveyId} {t.SurveyTitle} — {t.Task}",
        Status = t.Status
    }).ToList();

    private void SelectTask(TaskRow task)
    {
        SelectedEventId = SelectedEventId == task.Id ? null : task.Id;
    }

    private void ClearSelection()
    {
        SelectedEventId = null;
    }

    private List<string> AvailableReferenceDates { get; set; } = new();
    private List<int> AvailableSurveyIds { get; set; } = new();
    private List<string> AvailableSampleIds { get; set; } = new();
    private string SearchText { get; set; } = "";
    private DateTime? SelectedReferenceDate { get; set; }
    private int? SelectedSurveyId { get; set; }
    private string? SelectedSampleId { get; set; }
    private string? OptionsMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await RefreshFilterOptionsAsync();
    }

    private bool CanViewDetails =>
        SelectedReferenceDate.HasValue &&
        SelectedSurveyId.HasValue &&
        !string.IsNullOrWhiteSpace(SelectedSampleId);

    private string SelectedSurveyIdString => SelectedSurveyId?.ToString() ?? "";

    private async Task OnReferenceDateChanged()
    {
        await RefreshFilterOptionsAsync();
    }

    private async Task OnSurveyIdChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var parsed))
        {
            SelectedSurveyId = parsed;
        }
        else
        {
            SelectedSurveyId = null;
        }

        await RefreshFilterOptionsAsync();
    }

    private async Task OnSampleIdChanged(ChangeEventArgs e)
    {
        SelectedSampleId = e.Value?.ToString();
        await RefreshFilterOptionsAsync();
    }

    private async Task RefreshFilterOptionsAsync()
    {
        OptionsMessage = null;
        var options = await FetchFilterOptionsAsync();
        if (options is null)
        {
            OptionsMessage = "Unable to load selection options. Please try again.";
            return;
        }

        AvailableReferenceDates = options.AvailableReferenceDates;
        AvailableSurveyIds = options.AvailableSurveyIds;
        AvailableSampleIds = options.AvailableSampleIds;

        var cleared = false;
        if (SelectedReferenceDate.HasValue &&
            !AvailableReferenceDates.Contains(SelectedReferenceDate.Value.ToString("yyyy-MM-dd")))
        {
            SelectedReferenceDate = null;
            cleared = true;
        }

        if (SelectedSurveyId.HasValue &&
            !AvailableSurveyIds.Contains(SelectedSurveyId.Value))
        {
            SelectedSurveyId = null;
            cleared = true;
        }

        if (!string.IsNullOrWhiteSpace(SelectedSampleId) &&
            !AvailableSampleIds.Contains(SelectedSampleId))
        {
            SelectedSampleId = null;
            cleared = true;
        }

        if (cleared)
        {
            options = await FetchFilterOptionsAsync();
            if (options is not null)
            {
                AvailableReferenceDates = options.AvailableReferenceDates;
                AvailableSurveyIds = options.AvailableSurveyIds;
                AvailableSampleIds = options.AvailableSampleIds;
            }
        }

        if (AvailableReferenceDates.Count == 0 ||
            AvailableSurveyIds.Count == 0 ||
            AvailableSampleIds.Count == 0)
        {
            OptionsMessage = "No matches found for the current selections.";
        }
    }

    private async Task<app_blazor.Services.FilterOptionsResponse?> FetchFilterOptionsAsync()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);

        var query = new List<string>();
        if (SelectedReferenceDate.HasValue)
            query.Add($"referenceDate={SelectedReferenceDate.Value:yyyy-MM-dd}");
        if (SelectedSurveyId.HasValue)
            query.Add($"surveyId={SelectedSurveyId.Value}");
        if (!string.IsNullOrWhiteSpace(SelectedSampleId))
            query.Add($"sampleId={Uri.EscapeDataString(SelectedSampleId)}");

        var url = "api/survey-instances/filter-options";
        if (query.Count > 0)
            url += "?" + string.Join("&", query);

        return await client.GetFromJsonAsync<app_blazor.Services.FilterOptionsResponse>(url);
    }

    private void NavigateToSelectedDetails()
    {
        if (!CanViewDetails)
        {
            OptionsMessage = "Select Reference Date, Survey ID, and Sample ID to view details.";
            return;
        }

        var parts = new List<string>
        {
            $"referenceDate={SelectedReferenceDate!.Value:yyyy-MM-dd}",
            $"surveyId={SelectedSurveyId!.Value}",
            $"sampleId={Uri.EscapeDataString(SelectedSampleId!)}"
        };

        Navigation.NavigateTo($"/surveys/details?{string.Join("&", parts)}");
    }

    private IReadOnlyList<app_blazor.Services.SurveyInstance> RecentSurveyInstances =>
        SurveyInstanceService.Instances
            .OrderByDescending(i => i.ReferenceDate)
            .ThenByDescending(i => i.SurveyDate)
            .Take(10)
            .ToList();

    private string BuildDetailsHref(app_blazor.Services.SurveyInstance instance)
    {
        var parts = new List<string>
        {
            $"referenceDate={instance.ReferenceDate:yyyy-MM-dd}",
            $"surveyId={instance.SurveyId}",
            $"sampleId={Uri.EscapeDataString(instance.SampleId)}"
        };

        return $"/surveys/details?{string.Join("&", parts)}";
    }


    private static string GetSurveyLink(int surveyId) => $"/surveys/details/{surveyId}";

    private string GetPill(string status) => status switch
    {
        "In progress" => "pill-progress",
        "Blocked" => "pill-blocked",
        "Not started" => "pill-notstarted",
        "Overdue" => "pill-overdue",
        _ => ""
    };
}
