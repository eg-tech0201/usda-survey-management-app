        "enumId" => ("Lowest → Highest", "Highest → Lowest"),
        "managerId" => ("Lowest → Highest", "Highest → Lowest"),
        "coachId" => ("Lowest → Highest", "Highest → Lowest"),
        "surveyDate" => ("Oldest → Newest", "Newest → Oldest"),
        "referenceDate" => ("Oldest → Newest", "Newest → Oldest"),
