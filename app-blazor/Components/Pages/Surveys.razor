    private void OnColumnDrop(string targetKey)
    {
        if (string.IsNullOrWhiteSpace(DraggedColumnKey) || DraggedColumnKey == targetKey)
            return;

        var draggedIndex = Columns.FindIndex(c => c.Key == DraggedColumnKey);
        var targetIndex = Columns.FindIndex(c => c.Key == targetKey);
        if (draggedIndex < 0 || targetIndex < 0)
            return;

        var dragged = Columns[draggedIndex];
        Columns.RemoveAt(draggedIndex);
        if (draggedIndex < targetIndex)
            targetIndex--;
        Columns.Insert(targetIndex, dragged);
    }

    private async Task SaveColumnsAsDefaultAsync()
    {
        var preference = new SavedColumnPreference(
            Columns.Select(c => c.Key).ToList(),
            Columns.Where(c => !c.Visible).Select(c => c.Key).ToList());

        await Js.InvokeVoidAsync("smsSaveJson", ColumnPreferenceStorageKey, preference);
    }

    private async Task LoadSavedColumnsAsync()
    {
        try
        {
            var preference = await Js.InvokeAsync<SavedColumnPreference?>("smsLoadJson", ColumnPreferenceStorageKey);
            if (preference is null || preference.Order is null || preference.Order.Count == 0)
                return;

            var defaults = BuildDefaultColumns().ToDictionary(c => c.Key, c => c, StringComparer.OrdinalIgnoreCase);
            var ordered = new List<ColumnOption>();

            foreach (var key in preference.Order)
            {
                if (defaults.TryGetValue(key, out var column))
                {
                    ordered.Add(column);
                    defaults.Remove(key);
                }
            }

            ordered.AddRange(defaults.Values);
            var hidden = preference.HiddenKeys?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var column in ordered)
            {
                column.Visible = !hidden.Contains(column.Key);
            }

            Columns = ordered;
            StateHasChanged();
        }
        catch
        {
            // Ignore malformed saved preferences.
        }
    }

