    private static (string Asc, string Desc) GetSortLabels(string key)
    {
        if (key.Equals("status", StringComparison.OrdinalIgnoreCase))
            return ("Designer key order", "Reverse designer key");
        if (key.Equals("response_code", StringComparison.OrdinalIgnoreCase))
            return ("Status order", "Reverse status");
        if (key.EndsWith("_date", StringComparison.OrdinalIgnoreCase) || key.Equals("respdate", StringComparison.OrdinalIgnoreCase))
            return ("Oldest → Newest", "Newest → Oldest");
        if (key.EndsWith("_id", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("survey_id", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("sample_id", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("poid", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("target_poid", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("mseqnum", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("samp_no", StringComparison.OrdinalIgnoreCase))
        {
            return ("Lowest → Highest", "Highest → Lowest");
        }

        return ("Ascending (A → Z)", "Descending (Z → A)");
    }

    private static IComparable ToComparableFallback(string value)
    {
        if (DateTime.TryParse(value, out var date))
            return date;
        if (int.TryParse(value, out var number))
            return number;
        return ToAlphaNumericSortKey(value);
    }

    private static string ToAlphaNumericSortKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var input = value.ToUpperInvariant();
        var sb = new StringBuilder(input.Length + 12);
        var numberBuffer = new StringBuilder();

        foreach (var ch in input)
        {
            if (char.IsDigit(ch))
            {
                numberBuffer.Append(ch);
                continue;
            }

            if (numberBuffer.Length > 0)
            {
                sb.Append(numberBuffer.ToString().PadLeft(12, '0'));
                numberBuffer.Clear();
            }

            sb.Append(ch);
        }

        if (numberBuffer.Length > 0)
            sb.Append(numberBuffer.ToString().PadLeft(12, '0'));

        return sb.ToString();
    }

