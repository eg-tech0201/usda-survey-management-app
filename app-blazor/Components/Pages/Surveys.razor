    private async Task ToggleColumnMenuAsync(string key)
    {
        if (ActiveColumnMenuKey == key)
        {
            CloseColumnMenu();
            return;
        }

        ActiveColumnMenuKey = key;
        if (ColumnMenuAnchors.TryGetValue(key, out var anchor))
        {
            var rect = await Js.InvokeAsync<AnchorRect?>("smsGetRect", anchor);
            if (rect is not null)
            {
                const double menuWidth = 320;
                const double padding = 12;
                var left = rect.Left;
                if (left < padding) left = padding;
                if (left + menuWidth > rect.WindowWidth - padding)
                    left = rect.WindowWidth - padding - menuWidth;

                ColumnMenuLeft = left;
                ColumnMenuTop = rect.Bottom + 8;
            }
        }
    }

    private sealed class AnchorRect
    {
        public double Top { get; set; }
        public double Bottom { get; set; }
        public double Left { get; set; }
        public double Right { get; set; }
        public double WindowWidth { get; set; }
    }

