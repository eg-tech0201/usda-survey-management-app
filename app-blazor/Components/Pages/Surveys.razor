@page "/surveys/results"
@using System.Text
@inject IJSRuntime Js
@inject NavigationManager Navigation
@inject app_blazor.Services.SurveyInstanceService SurveyInstanceService

<h1 class="page-h1">Surveys</h1>
<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb breadcrumb-mini mb-0">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Surveys</li>
    </ol>
</nav>

<div class="surveys-toolbar">
    <div class="toolbar-left">
        @if (ShowFilters)
        {
            <div class="filters-backdrop" @onclick="CloseFilters"></div>
        }
        <div class="search-shell" @ref="_filtersAnchor">
            <div class="search-input-row">
                <button class="search-icon-button" type="submit" title="Search">
                    <span class="bi bi-search" aria-hidden="true"></span>
                </button>
                <input class="survey-search search-input" placeholder="Search survey list (ID / title)" @bind="SearchText"
                       @bind:event="oninput" @ref="_searchInput" />

                <button class="search-filter-button" type="button" @onclick="ToggleFilters" title="Filters">
                    <span class="bi bi-sliders" aria-hidden="true"></span>
                    <span class="filter-label">Filters</span>
                    @if (FilterAppliedCount > 0)
                    {
                        <span class="filter-count">(@FilterAppliedCount)</span>
                    }
                </button>
            </div>
            @if (AppliedFilterChips.Any())
            {
                <div class="search-chips search-chips-persistent">
                    @foreach (var chip in AppliedFilterChips)
                    {
                        <button type="button" class="chip" @onclick="chip.OnRemove">
                            <span class="chip-x">×</span>
                            <span>@chip.Label</span>
                        </button>
                    }
                </div>
            }

            @if (ShowFilters)
            {
                <div class="filters-pop" @onclick:stopPropagation="true" @ref="_filtersPop">
                    <div class="filters-header">
                        <div class="filters-title">Filters</div>
                        @if (AppliedFilterChips.Any())
                        {
                            <div class="filters-chips">
                                @foreach (var chip in AppliedFilterChips)
                                {
                                    <button type="button" class="chip" @onclick="chip.OnRemove">
                                        <span class="chip-x">×</span>
                                        <span>@chip.Label</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    <div class="filters-group">
                        <div class="filters-subtitle">Start Date – Stop Date</div>
                        <div class="filters-inline">
                            <InputDate class="select-lite" @bind-Value="StartDateFilter" />
                            <InputDate class="select-lite" @bind-Value="StopDateFilter" />
                        </div>
                    </div>

                    <div class="filters-group">
                        <div class="filters-subtitle">Reference Date</div>
                        <div class="filters-inline">
                            <InputSelect class="select-lite" @bind-Value="ReferenceMonth" @bind-Value:after="OnReferenceDatePartChanged">
                                <option value="">MM</option>
                                @foreach (var month in ReferenceMonthOptions)
                                {
                                    <option value="@month">@month</option>
                                }
                            </InputSelect>
                            <InputSelect class="select-lite" @bind-Value="ReferenceDay" @bind-Value:after="OnReferenceDatePartChanged">
                                <option value="">DD</option>
                                @foreach (var day in ReferenceDayOptions)
                                {
                                    <option value="@day">@day</option>
                                }
                            </InputSelect>
                            <InputSelect class="select-lite" @bind-Value="ReferenceYear" @bind-Value:after="OnReferenceDatePartChanged">
                                <option value="">YYYY</option>
                                @foreach (var year in ReferenceYearOptions)
                                {
                                    <option value="@year">@year</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="filters-group">
                        <div class="filters-subtitle">States</div>
                        <div class="filters-checks">
                            @foreach (var state in States)
                            {
                                <label class="check-pill">
                                    <input type="checkbox"
                                           checked="@StateSelections.Contains(state)"
                                           @onchange="e => ToggleSelection(StateSelections, state, e)" />
                                    <span>@state</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filters-group">
                        <div class="filters-subtitle">Mode</div>
                        <div class="filters-checks">
                            @foreach (var mode in Modes)
                            {
                                <label class="check-pill">
                                    <input type="checkbox"
                                           checked="@ModeSelections.Contains(mode)"
                                           @onchange="e => ToggleSelection(ModeSelections, mode, e)" />
                                    <span>@mode</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filters-group">
                        <div class="filters-subtitle">Show # of results</div>
                        <select class="select-lite" @bind="PageSizeString" @bind:after="OnPageSizeChanged">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="All">All</option>
                        </select>
                    </div>

                    <div class="filters-group">
                        <div class="filters-subtitle">Status</div>
                        <div class="filters-checks">
                            @foreach (var status in StatusOptions)
                            {
                                <label class="check-pill">
                                    <input type="checkbox"
                                           checked="@StatusSelections.Contains(status)"
                                           @onchange="e => ToggleSelection(StatusSelections, status, e)" />
                                    <span>@status</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filters-actions">
                        <button class="button-lite" @onclick="ClearFilters">Clear</button>
                        <button class="button-primary" @onclick="CloseFilters">Done</button>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="toolbar-meta">
        <div class="toolbar-right">
            <div class="pager">
                <button class="button-lite" @onclick="PrevPage" disabled="@IsPrevDisabled">‹</button>

                <span class="pager-text">
                    @PageSummary
                </span>

                <button class="button-lite" @onclick="NextPage" disabled="@IsNextDisabled">›</button>
            </div>

            <div class="pagesize">
                <span class="pagesize-label">Rows:</span>
                <select class="select-lite" @bind="PageSizeString" @bind:after="OnPageSizeChanged">
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="All">All</option>
                </select>
            </div>

            <div class="columns-menu">
                <button class="button-lite" type="button" @onclick="ToggleColumnsMenu">Customize Columns</button>
                @if (ShowColumnsMenu)
                {
                    <div class="columns-backdrop" @onclick="CloseColumnsMenu"></div>
                    <div class="columns-pop" @onclick:stopPropagation="true">
                        <div class="columns-header">
                            <div class="columns-title">Customize Columns</div>
                            <button type="button" class="columns-close" @onclick="CloseColumnsMenu">×</button>
                        </div>
                        <div class="columns-body">
                            @foreach (var column in Columns)
                            {
                                <div class="columns-item columns-item-draggable"
                                     draggable="true"
                                     @ondragstart="@(() => OnColumnDragStart(column.Key))"
                                     @ondragover:preventDefault="true"
                                     @ondrop="@(() => OnColumnDrop(column.Key))">
                                    <span class="column-grip bi bi-grip-vertical" aria-hidden="true"></span>
                                    <label class="columns-item-label">
                                        <input type="checkbox" checked="@column.Visible" @onchange="e => ToggleColumn(column, e)" />
                                        <span>@column.Label</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="columns-actions">
                            <button class="button-lite compact" type="button" @onclick="SelectAllColumns">Select all</button>
                            <button class="button-lite compact" type="button" @onclick="SaveColumnsAsDefaultAsync">Save as Default</button>
                            <button class="button-lite compact" type="button" @onclick="ResetColumns">Reset</button>
                            <button class="button-primary compact" type="button" @onclick="CloseColumnsMenu">Done</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(ActiveColumnMenuKey))
{
    var activeKey = ActiveColumnMenuKey!;
    var activeLabel = Columns.FirstOrDefault(c => c.Key == activeKey)?.Label ?? "Column";
    <div class="column-menu-backdrop" @onclick="CloseColumnMenu"></div>
    <div class="column-menu-floating" style="top:@($"{ColumnMenuTop}px"); left:@($"{ColumnMenuLeft}px")">
        @BuildColumnMenu(activeLabel, activeKey)
    </div>
}

<div class="table-wrap">
    <table class="table-surveys">
        <thead>
            <tr>
                @foreach (var column in VisibleColumns)
                {
                    <th>@ColumnHeader(column.Key, column.Label)</th>
                }
            </tr>
        </thead>

        <tbody>
            @foreach (var s in PagedRows)
            {
                <tr class="survey-row" @onclick="() => NavigateToDetails(s)">
                    @foreach (var column in VisibleColumns)
                    {
                        if (column.Key.Equals("survey_id", StringComparison.OrdinalIgnoreCase))
                        {
                            <td class="td-id">
                                <a class="survey-link" href="@BuildDetailsHref(s)" @onclick:preventDefault="true" @onclick="() => NavigateToDetails(s)">@GetColumnValue(s, column.Key)</a>
                            </td>
                        }
                        else if (column.Key.Equals("survey_title", StringComparison.OrdinalIgnoreCase))
                        {
                            <td class="td-title">
                                <a class="survey-link" href="@BuildDetailsHref(s)" @onclick:preventDefault="true" @onclick="() => NavigateToDetails(s)">@GetColumnValue(s, column.Key)</a>
                            </td>
                        }
                        else
                        {
                            <td>@GetColumnValue(s, column.Key)</td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ShowUnavailableAlert)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Survey Not Available</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseUnavailableAlert"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">@UnavailableAlertMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="CloseUnavailableAlert">OK</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "q")] public string? Query { get; set; }
    [SupplyParameterFromQuery(Name = "status")] public string? QueryStatus { get; set; }
    [SupplyParameterFromQuery(Name = "viewAll")] public bool ViewAll { get; set; }
    [SupplyParameterFromQuery(Name = "start")] public DateTime? StartDateQuery { get; set; }
    [SupplyParameterFromQuery(Name = "stop")] public DateTime? StopDateQuery { get; set; }
    [SupplyParameterFromQuery(Name = "state")] public string? StateQuery { get; set; }
    [SupplyParameterFromQuery(Name = "mode")] public string? ModeQuery { get; set; }
    [SupplyParameterFromQuery(Name = "size")] public string? SizeQuery { get; set; }
    [SupplyParameterFromQuery(Name = "referenceDate")] public string? ReferenceDateQuery { get; set; }

    // ---- DEMO model (you already have this) ----
    private record SurveyRow(
        int Id,
        string SampleId,
        string Poid,
        string TargetPoid,
        DateTime ReferenceDate,
        DateTime SurveyDate,
        string Title,
        string OmbNumber,
        DateTime OmbExpires,
        string SampleName,
        DateTime StartDate,
        DateTime StopDate,
        string Status,
        string State,
        string Region,
        string Mode,
        string ProjectCode,
        string SubTitle,
        string StateId,
        string StateAlpha,
        string DcmsCodeId,
        string OpDomStatusId,
        string EnumeratorId,
        string EnumeratorName,
        string ManagerId,
        string ManagerName,
        string CoachId,
        string CoachName,
        string ResponseCode,
        string EnumeratorNotes,
        Dictionary<string, string> Metadata
    );

    private List<SurveyRow> SurveyRows = new();
    private IEnumerable<ColumnOption> VisibleColumns => Columns.Where(c => c.Visible);

    // ---- toolbar state ----
    private string SearchText { get; set; } = "";
    private bool ShowFilters { get; set; } = false;
    private ElementReference _searchInput;
    private ElementReference _filtersAnchor;
    private ElementReference _filtersPop;
    private DateTime? StartDateFilter { get; set; }
    private DateTime? StopDateFilter { get; set; }

    private readonly List<string> States = new()
    {
        "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "DC", "FL",
        "GA", "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME",
        "MD", "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH",
        "NJ", "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI",
        "SC", "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY", "PR"
    };
    private readonly List<string> Modes = new() { "CAWI", "CATI", "CAPI", "Paper" };
    private readonly List<string> StatusOptions = new() { "IN HQ REVIEW", "Published", "NASS Review", "Emergency Edit", "Draft" };

    private HashSet<string> StateSelections { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> ModeSelections { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> StatusSelections { get; } = new(StringComparer.OrdinalIgnoreCase);
    private DateTime? SelectedReferenceDate { get; set; }
    private int? ReferenceMonth { get; set; }
    private int? ReferenceDay { get; set; }
    private int? ReferenceYear { get; set; }
    private bool ShowColumnsMenu { get; set; }
    private List<ColumnOption> Columns { get; set; } = new();
    private string? ActiveColumnMenuKey { get; set; }
    private double ColumnMenuTop { get; set; }
    private double ColumnMenuLeft { get; set; }
    private readonly Dictionary<string, ElementReference> ColumnMenuAnchors = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> ColumnFilters = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> ColumnFilterDrafts = new(StringComparer.OrdinalIgnoreCase);
    private string? SortKey { get; set; }
    private bool SortAscending { get; set; } = true;
    private const string ColumnPreferenceStorageKey = "sms.surveys.columns.v1";
    private string? DraggedColumnKey { get; set; }
    private bool ShowUnavailableAlert { get; set; }
    private string UnavailableAlertMessage { get; set; } = "The selected survey instance is not yet available.";

    // ---- paging ----
    private int PageIndex { get; set; } = 0;
    private int PageSize { get; set; } = 10; // default
    private string PageSizeString { get; set; } = "10";
    private bool PageSizeTouched { get; set; }

    protected override void OnInitialized()
    {
        var recordIndexByKey = SurveyInstanceService.Instances
            .Select(i => i.SurveyId)
            .Distinct()
            .SelectMany(id => SurveyInstanceService.GetSurveyRecordIndex(id))
            .GroupBy(r => BuildRecordKey(r.SurveyId, r.SampleId, r.ReferenceDate), StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                g => g.Key,
                g => g.First(),
                StringComparer.OrdinalIgnoreCase);

        SurveyRows = SurveyInstanceService.Instances
            .Select(i =>
            {
                recordIndexByKey.TryGetValue(BuildRecordKey(i.SurveyId, i.SampleId, i.ReferenceDate), out var recordIndex);
                var detail = SurveyInstanceService.GetDetail(i.ReferenceDate, i.SurveyId, i.SampleId);
                var metadata = BuildMetadata(i, recordIndex, detail?.FullRecord ?? new List<app_blazor.Services.DetailField>());
                return new SurveyRow(
                    i.SurveyId,
                    i.SampleId,
                    recordIndex?.Poid ?? "",
                    recordIndex?.TargetPoid ?? "",
                    i.ReferenceDate,
                    i.SurveyDate,
                    i.Title,
                    i.OmbNumber,
                    i.OmbExpires,
                    i.SampleName,
                    i.SurveyStartDate,
                    i.SurveyStopDate,
                    GetGridStatus(i),
                    i.State,
                    i.Region,
                    i.Mode,
                    i.ProjectCode,
                    i.SubTitle,
                    i.StateId,
                    i.StateAlpha,
                    i.DcmsCodeId,
                    i.OpDomStatusId,
                    i.EnumeratorId,
                    i.EnumeratorName,
                    i.ManagerId,
                    i.ManagerName,
                    i.CoachId,
                    i.CoachName,
                    i.ResponseCode,
                    i.EnumeratorNotes,
                    metadata);
            })
            .ToList();
        PageSizeString = PageSize == 0 ? "All" : PageSize.ToString(); // will be "10"
        Columns = BuildDefaultColumns();
    }

    protected override void OnParametersSet()
    {
        if (ViewAll)
        {
            SearchText = "";
            StartDateFilter = null;
            StopDateFilter = null;
            StateSelections.Clear();
            ModeSelections.Clear();
            StatusSelections.Clear();
            PageSizeTouched = false;
            PageSize = 10;
            PageSizeString = "10";
        }

        if (!string.IsNullOrWhiteSpace(Query))
        {
            SearchText = Query.Trim();
        }

        StatusSelections.Clear();
        StatusSelections.UnionWith(ParseCsv(QueryStatus));

        if (StartDateQuery.HasValue)
        {
            StartDateFilter = StartDateQuery;
        }

        if (StopDateQuery.HasValue)
        {
            StopDateFilter = StopDateQuery;
        }

        StateSelections.Clear();
        StateSelections.UnionWith(ParseCsv(StateQuery));


        ModeSelections.Clear();
        ModeSelections.UnionWith(ParseCsv(ModeQuery));

        if (!string.IsNullOrWhiteSpace(SizeQuery))
        {
            PageSizeString = SizeQuery;
            OnPageSizeChanged();
            PageSizeTouched = true;
        }

        if (DateTime.TryParse(ReferenceDateQuery, out var parsedReferenceDate))
        {
            SelectedReferenceDate = parsedReferenceDate.Date;
            ReferenceYear = SelectedReferenceDate.Value.Year;
            ReferenceMonth = SelectedReferenceDate.Value.Month;
            ReferenceDay = SelectedReferenceDate.Value.Day;
        }
        else
        {
            ClearReferenceDateFilter();
        }
    }

    // Recompute on every render (fine for demo sizes)
    private List<SurveyRow> FilteredRows => ApplySurveyFilters().ToList();

    private IEnumerable<SurveyRow> PagedRows
    {
        get
        {
            var rows = FilteredRows;

            if (PageSize <= 0) return rows;

            // clamp PageIndex if filters shrink results
            var maxPage = Math.Max(0, (int)Math.Ceiling(rows.Count / (double)PageSize) - 1);
            if (PageIndex > maxPage) PageIndex = maxPage;

            return rows.Skip(PageIndex * PageSize).Take(PageSize);
        }
    }

    private string PageSummary
    {
        get
        {
            var total = FilteredRows.Count;
            if (total == 0) return "0 results";

            if (PageSize <= 0) return $"1–{total} of {total}";

            var start = PageIndex * PageSize + 1;
            var end = Math.Min(total, (PageIndex + 1) * PageSize);
            return $"{start}–{end} of {total}";
        }
    }

    private bool IsPrevDisabled => PageIndex <= 0 || PageSize <= 0;
    private bool IsNextDisabled
    {
        get
        {
            if (PageSize <= 0) return true;
            var total = FilteredRows.Count;
            return (PageIndex + 1) * PageSize >= total;
        }
    }

    private void PrevPage()
    {
        if (PageIndex > 0) PageIndex--;
    }

    private void NextPage()
    {
        if (!IsNextDisabled) PageIndex++;
    }

    private void OnPageSizeChanged()
    {
        // reset to first page whenever page size changes
        PageIndex = 0;
        PageSizeTouched = true;

        PageSizeString = PageSizeString?.Trim() ?? "20";
        if (PageSizeString.Equals("All", StringComparison.OrdinalIgnoreCase))
        {
            PageSize = 0; // 0 means ALL
        }
        else if (!int.TryParse(PageSizeString, out var n) || n <= 0)
        {
            PageSize = 20;
            PageSizeString = "20";
        }
        else
        {
            PageSize = n;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSavedColumnsAsync();
        }

        if (ShowFilters)
            await Js.InvokeVoidAsync("smsPositionFilterPopover", _filtersAnchor, _filtersPop);
    }

    private async Task ToggleFilters()
    {
        ShowFilters = !ShowFilters;
        if (!ShowFilters)
        {
            await FocusSearchInput();
        }
    }

    private async Task CloseFilters()
    {
        ShowFilters = false;
        await FocusSearchInput();
    }

    private void ClearFilters()
    {
        StatusSelections.Clear();
        SearchText = "";
        StartDateFilter = null;
        StopDateFilter = null;
        StateSelections.Clear();
        ModeSelections.Clear();
        ClearReferenceDateFilter();
        PageIndex = 0;
        PageSizeTouched = false;
        PageSize = 10;
        PageSizeString = "10";
    }

    private void NavigateToDetails(SurveyRow row)
    {
        if (row.Status.Equals("IN HQ REVIEW", StringComparison.OrdinalIgnoreCase))
        {
            UnavailableAlertMessage = "This survey is currently IN HQ REVIEW and not yet available.";
            ShowUnavailableAlert = true;
            return;
        }

        Navigation.NavigateTo(BuildDetailsHref(row));
    }

    private void CloseUnavailableAlert()
    {
        ShowUnavailableAlert = false;
    }

    private IEnumerable<SurveyRow> ApplySurveyFilters()
    {
        // ✅ key fix: SurveyRows (your list), NOT Surveys
        IEnumerable<SurveyRow> q = SurveyRows;

        if (SelectedReferenceDate.HasValue)
        {
            var referenceDate = SelectedReferenceDate.Value.Date;
            q = q.Where(s => s.ReferenceDate.Date == referenceDate);
        }

        // search
        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            var t = SearchText.Trim().ToLowerInvariant();
            q = q.Where(s =>
            s.Id.ToString().Contains(t) ||
            s.Title.ToLowerInvariant().Contains(t) ||
            s.OmbNumber.ToLowerInvariant().Contains(t) ||
            s.SampleName.ToLowerInvariant().Contains(t) ||
            s.SampleId.ToLowerInvariant().Contains(t) ||
            s.Poid.ToLowerInvariant().Contains(t) ||
            s.TargetPoid.ToLowerInvariant().Contains(t));
        }

        if (StatusSelections.Count > 0)
        {
            q = q.Where(s => StatusSelections.Contains(s.Status));
        }

        if (StartDateFilter.HasValue)
        {
            q = q.Where(s => s.StartDate.Date >= StartDateFilter.Value.Date);
        }

        if (StopDateFilter.HasValue)
        {
            q = q.Where(s => s.StopDate.Date <= StopDateFilter.Value.Date);
        }

        if (StateSelections.Count > 0)
        {
            q = q.Where(s => StateSelections.Contains(s.State));
        }


        if (ModeSelections.Count > 0)
        {
            q = q.Where(s => ModeSelections.Contains(s.Mode));
        }

        foreach (var filter in ColumnFilters.Where(f => !string.IsNullOrWhiteSpace(f.Value)))
        {
            var term = filter.Value.Trim();
            if (filter.Key.Equals("status", StringComparison.OrdinalIgnoreCase))
            {
                q = q.Where(s => string.Equals(s.Status, term, StringComparison.OrdinalIgnoreCase));
            }
            else
            {
                q = q.Where(s => GetColumnValue(s, filter.Key)
                    .Contains(term, StringComparison.OrdinalIgnoreCase));
            }
        }

        if (!string.IsNullOrWhiteSpace(SortKey))
        {
            return SortAscending
                ? q.OrderBy(s => GetSortValue(s, SortKey!))
                : q.OrderByDescending(s => GetSortValue(s, SortKey!));
        }

        return q.OrderBy(s => s.Id);
    }

    private IEnumerable<FilterChip> AppliedFilterChips => BuildFilterChips();
    private int FilterAppliedCount => AppliedFilterChips.Count();

    private IEnumerable<FilterChip> BuildFilterChips()
    {
        var chips = new List<FilterChip>();

        chips.AddRange(StateSelections.Select(s => new FilterChip($"State: {s}", () => StateSelections.Remove(s))));
        chips.AddRange(ModeSelections.Select(m => new FilterChip($"Mode: {m}", () => ModeSelections.Remove(m))));
        chips.AddRange(StatusSelections.Select(s => new FilterChip($"Status: {s}", () => StatusSelections.Remove(s))));

        if (SelectedReferenceDate.HasValue)
            chips.Add(new FilterChip($"Reference Date: {SelectedReferenceDate.Value:MM-dd-yyyy}", ClearReferenceDateFilter));

        if (StartDateFilter.HasValue)
            chips.Add(new FilterChip($"Start Date: {StartDateFilter.Value:MM-dd-yyyy}", () => StartDateFilter = null));

        if (StopDateFilter.HasValue)
            chips.Add(new FilterChip($"End Date: {StopDateFilter.Value:MM-dd-yyyy}", () => StopDateFilter = null));

        if (PageSizeTouched)
            chips.Add(new FilterChip($"Results: {PageSizeString}", () =>
            {
                PageSizeString = "10";
                OnPageSizeChanged();
            }));

        return chips;
    }

