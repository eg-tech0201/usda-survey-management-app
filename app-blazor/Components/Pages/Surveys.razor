    private static Dictionary<string, string> BuildMetadata(
        app_blazor.Services.SurveyInstance instance,
        app_blazor.Services.SurveyRecordIndexItem? recordIndex,
        List<app_blazor.Services.DetailField> fullRecord)
    {
        var metadata = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var field in fullRecord)
        {
            metadata[NormalizeFieldKey(field.Field)] = field.Value ?? "";
        }

        metadata["project_code"] = instance.ProjectCode;
        metadata["sample_id"] = instance.SampleId;
        metadata["sample_name"] = instance.SampleName;
        metadata["survey_id"] = instance.SurveyId.ToString();
        metadata["survey_title"] = instance.Title;
        metadata["survey_subtitle"] = instance.SubTitle;
        metadata["survey_date"] = instance.SurveyDate.ToString("MM-dd-yyyy");
        metadata["start_date"] = instance.SurveyStartDate.ToString("MM-dd-yyyy");
        metadata["stop_date"] = instance.SurveyStopDate.ToString("MM-dd-yyyy");
        metadata["reference_date"] = instance.ReferenceDate.ToString("MM-dd-yyyy");
        metadata["state_id"] = instance.StateId;
        metadata["state_alpha"] = instance.StateAlpha;
        metadata["state_abbrev"] = instance.StateAlpha;
        metadata["dcms_code_id"] = instance.DcmsCodeId;
        metadata["op_dom_status_id"] = instance.OpDomStatusId;
        metadata["enumerator_id"] = instance.EnumeratorId;
        metadata["enumerator_name"] = instance.EnumeratorName;
        metadata["manager_id"] = instance.ManagerId;
        metadata["manager_name"] = instance.ManagerName;
        metadata["coach_id"] = instance.CoachId;
        metadata["coach_name"] = instance.CoachName;
        metadata["enum_notes"] = instance.EnumeratorNotes;
        metadata["response_code"] = instance.ResponseCode;
        metadata["status"] = GetGridStatus(instance);
        metadata["poid"] = recordIndex?.Poid ?? metadata.GetValueOrDefault("poid", "");
        metadata["target_poid"] = recordIndex?.TargetPoid ?? metadata.GetValueOrDefault("target_poid", "");
        metadata["latitude"] = metadata.GetValueOrDefault("latitude", "");
        metadata["longitude"] = metadata.GetValueOrDefault("longitude", "");

        return metadata;
    }

    private static string NormalizeFieldKey(string field)
    {
        var lowered = field.Trim().ToLowerInvariant();
        var sb = new StringBuilder(lowered.Length);
        var priorUnderscore = false;

        foreach (var ch in lowered)
        {
            if (char.IsLetterOrDigit(ch))
            {
                sb.Append(ch);
                priorUnderscore = false;
            }
            else if (!priorUnderscore)
            {
                sb.Append('_');
                priorUnderscore = true;
            }
        }

        var normalized = sb.ToString().Trim('_');
        return normalized.Replace("__", "_");
    }

    private static string GetGridStatus(app_blazor.Services.SurveyInstance instance)
    {
        if (instance.Status.Equals("IN HQ REVIEW", StringComparison.OrdinalIgnoreCase))
            return "IN HQ REVIEW";

        var key = GetSurveyDesignerKey(instance.StateAlpha, instance.StateId, instance.SurveyId);
        return key switch
        {
            "P" => "Published",
            "R" => "NASS Review",
            "E" => "Emergency Edit",
            _ => "Draft"
        };
    }

    private static string GetSurveyDesignerKey(string stateAlpha, string stateId, int surveyId)
    {
        var statuses = new[] { "P", "R", "D", "E" };
        var seed = HashCode.Combine(stateAlpha, stateId, surveyId);
        return statuses[Math.Abs(seed) % statuses.Length];
    }

    private string BuildDetailsHref(SurveyRow row)
