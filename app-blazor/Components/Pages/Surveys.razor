        => $"{surveyId}|{sampleId}|{referenceDate:yyyy-MM-dd}";

    private static string GetGridStatus(app_blazor.Services.SurveyInstance instance)
    {
        if (instance.Status.Equals("IN HQ REVIEW", StringComparison.OrdinalIgnoreCase))
            return "IN HQ REVIEW";

        var key = GetSurveyDesignerKey(instance.StateAlpha, instance.StateId, instance.SurveyId);
        return key switch
        {
            "P" => "Published",
            "R" => "NASS Review",
            "E" => "Emergency Edit",
            _ => "Draft"
        };
    }

    private static string GetSurveyDesignerKey(string stateAlpha, string stateId, int surveyId)
    {
        var statuses = new[] { "P", "R", "D", "E" };
        var seed = HashCode.Combine(stateAlpha, stateId, surveyId);
        return statuses[Math.Abs(seed) % statuses.Length];
    }

    private string BuildDetailsHref(SurveyRow row)
    {
        var parts = new List<string>
        {
            $"referenceDate={row.ReferenceDate:yyyy-MM-dd}",
            $"surveyId={row.Id}",
            $"sampleId={Uri.EscapeDataString(row.SampleId)}"
        };

        return $"/surveys/details?{string.Join("&", parts)}";
    }

